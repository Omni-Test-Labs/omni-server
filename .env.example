# Example environment configuration for Omni-Server

# Server Settings
APP_NAME=omni-server
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./omni.db

# Task Queue Settings
TASK_RETENTION_SECONDS=604800
MAX_PENDING_TASKS_PER_DEVICE=10

# Heartbeat Settings
HEARTBEAT_TIMEOUT_SECONDS=300
